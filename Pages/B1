                if (cls.resources && cls.resources.length > 0) {
                    cls.resources.forEach(res => {
                        resourcesHTML += `
                            <div class="resource-item">
                                <span class="resource-tag">${res.tag}</span>
                                <a href="${res.link}" target="_blank">${res.text}</a>
                            </div>`;
                    });
                } else {
                    resourcesHTML = `<div class="resource-item" style="color: #666; font-style: italic; font-size: 0.9em;">No resources added yet.</div>`;
                }

                classesHTML += `
                    <div class="class-block">
                        <div class="class-header" onclick="toggleElement('${cls.class_id}')">
                            ▶ ${cls.title}
                        </div>
                        <div id="${cls.class_id}" class="class-content">
                            <div class="resource-item">
                                <strong>🎯 Objective:</strong> ${cls.objective}
                            </div>
                            <div class="resource-item">
                                <span class="resource-tag" style="background-color: var(--smart-blue);">Warm-Up</span> 
                                <strong>${cls.warmup}</strong>
                            </div>
                            ${resourcesHTML}
                        </div>
                    </div>`;
            });

            const unitHTML = `
