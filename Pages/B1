                    <div class="unit-header" onclick="toggleElement('${unit.unit_id}')">
                        ${unit.title}
                    </div>
                    <div id="${unit.unit_id}" class="unit-content">
                        ${classesHTML}
                    </div>
                </div>`;
            
            container.innerHTML += unitHTML;
        });

        // 3. INTERACTIVITY
        function toggleElement(id) {
            const el = document.getElementById(id);
            el.classList.toggle("active");
        }

        document.addEventListener("DOMContentLoaded", function() {
            var savedNames = localStorage.getItem("smart_students");
            if(savedNames) {
                document.getElementById("studentList").value = savedNames;
            }
        });

        function spinRoulette() {
            var input = document.getElementById("studentList").value;
            localStorage.setItem("smart_students", input);
            if(!input) {
                alert("Please add some names first!");
                return;
            }
            var names = input.split(",").map(n => n.trim()).filter(n => n !== "");
            if(names.length > 0) {
                var winner = names[Math.floor(Math.random() * names.length)];
                document.getElementById("rouletteResult").innerText = "Result: " + winner + "!";
            }
        }

        function resetRoulette() {
            document.getElementById("studentList").value = "";
            document.getElementById("rouletteResult").innerText = "";
            localStorage.removeItem("smart_students");
        }
